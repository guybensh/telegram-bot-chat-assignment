# Shared secrets, loaded for EVERY config. Copy to .env (gitignored).
# Per-mode settings live in .env.webhook / .env.poll — select via APP_CONFIG
# (default "webhook"). docker-compose reads this file from the repo root.

# Telegram bot token created via BotFather.
TELEGRAM_BOT_TOKEN=

# Max simultaneous active conversations the bot will accept (default 1).
# MAX_ACTIVE_CHATS=1
