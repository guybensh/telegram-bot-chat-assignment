# Copy to .env and fill in. .env is gitignored; .env.example is committed.
# docker-compose reads this file automatically from the repo root.

# Telegram bot token created via BotFather.
TELEGRAM_BOT_TOKEN=

# How the backend handles Telegram: poll (default) | webhook | mock.
# mock runs with no live bot (simulated delivery + a fake incoming feed).
# TELEGRAM_MODE=poll

# Webhook mode only: public HTTPS base URL Telegram should push updates to.
# TELEGRAM_WEBHOOK_URL=
# TELEGRAM_WEBHOOK_SECRET=

# Max simultaneous active conversations the bot will accept (default 1).
# MAX_ACTIVE_CHATS=1
