# General app config. Copy to .env (gitignored).
# Per-bot secrets live in backend/app/config/bots.json — see backend/app/config/bots.json.example

# Optional override for the bots credentials file (prod: mount/inject path)
# BOTS_CONFIG_PATH=/run/secrets/bots.json

# Default max active conversations when a bot JSON file omits max_active_chats.
DEFAULT_MAX_ACTIVE_CHATS=1

# How the backend handles Telegram: webhook | poll
TELEGRAM_MODE=webhook

TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=my_telegram_secret

CORS_ALLOWED_ORIGINS=http://localhost:5173
