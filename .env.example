# General app config. Copy to .env (gitignored).
# Per-bot secrets live in backend/config/bots/*.json — see backend/config/bots/example.json.example

# Default max active conversations when a bot JSON file omits max_active_chats.
DEFAULT_MAX_ACTIVE_CHATS=10

# How the backend handles Telegram: webhook | poll | mock (dev only)
TELEGRAM_MODE=webhook

TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=

CORS_ALLOWED_ORIGINS=http://localhost:5173
