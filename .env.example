# Default config (webhook / production). Copy to .env (gitignored).
# For local dev with polling, layer .env.development on top:
#   ENVIRONMENT=development uvicorn app.main:app --reload

# Max simultaneous active conversations the bot will accept.
MAX_ACTIVE_CHATS=1

# Telegram bot token created via BotFather.
TELEGRAM_BOT_TOKEN=

# How the backend handles Telegram: webhook | poll | mock (dev only)
TELEGRAM_MODE=webhook

# Telegram Bot API base URL (override only for testing/mocking).
TELEGRAM_API_BASE=https://api.telegram.org\

# Webhook mode only — public HTTPS base URL Telegram should POST updates to.
# The bot token is appended as the final path segment, e.g.
# {TELEGRAM_WEBHOOK_URL}{TELEGRAM_WEBHOOK_PATH}/{TELEGRAM_BOT_TOKEN}
TELEGRAM_WEBHOOK_URL=

# Webhook route prefix (bot token is appended for setWebhook and the POST route).
TELEGRAM_WEBHOOK_PATH=/telegram/webhook

TELEGRAM_WEBHOOK_SECRET=Secret_Key_For_Bot_Id_
