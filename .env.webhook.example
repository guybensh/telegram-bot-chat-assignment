# Webhook config (the DEFAULT). Copy to .env.webhook (gitignored).
# Loaded by default: `uvicorn app.main:app`  (APP_CONFIG defaults to "webhook")
# Layered on top of the shared .env (which holds TELEGRAM_BOT_TOKEN).

TELEGRAM_MODE=webhook

# Public HTTPS base URL Telegram should POST updates to — e.g. an ngrok URL.
# The webhook path (/telegram/webhook) is appended automatically.
TELEGRAM_WEBHOOK_URL=https://your-tunnel.ngrok-free.app

# Optional shared secret; Telegram echoes it in the
# X-Telegram-Bot-Api-Secret-Token header, which the webhook route validates.
TELEGRAM_WEBHOOK_SECRET=
